# =============================================================================
# SWE-Jobs v2 — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase / PostgreSQL
# -----------------------------------------------------------------------------
DB_HOST=your-project.supabase.co
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_GROUP_ID=-1001234567890

# -----------------------------------------------------------------------------
# Topic Thread IDs
# Set each to the thread_id of the corresponding Telegram topic.
# Leave blank to skip that topic.
# -----------------------------------------------------------------------------
TOPIC_GENERAL=
TOPIC_BACKEND=
TOPIC_FRONTEND=
TOPIC_MOBILE=
TOPIC_DEVOPS=
TOPIC_QA=
TOPIC_AI_ML=
TOPIC_CYBERSECURITY=
TOPIC_GAMEDEV=
TOPIC_BLOCKCHAIN=
TOPIC_EGYPT=
TOPIC_SAUDI=
TOPIC_INTERNSHIPS=
TOPIC_ERP=

# -----------------------------------------------------------------------------
# API Keys (all optional — sources are skipped if key is absent)
# -----------------------------------------------------------------------------
RAPIDAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
FINDWORK_API_KEY=
JOOBLE_API_KEY=
REED_API_KEY=
MUSE_API_KEY=

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
ADMIN_TELEGRAM_ID=
SEED_MODE=false
